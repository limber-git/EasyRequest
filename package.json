{
  "name": "easyrequest",
  "displayName": "EasyRequest",
  "description": "Cliente HTTP nativo de VS Code con descubrimiento de APIs.",
  "version": "0.1.0",
  "publisher": "ltolaba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/limber-git/EasyRequest.git"
  },
  "homepage": "https://github.com/limber-git/EasyRequest#readme",
  "bugs": {
    "url": "https://github.com/limber-git/EasyRequest/issues"
  },
  "icon": "assets/icon.png",
  "preview": true,
  "galleryBanner": {
    "color": "#16324F",
    "theme": "dark"
  },
  "keywords": [
    "http",
    "rest",
    "api",
    "openapi",
    "swagger",
    "asp.net",
    "request",
    "client"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "easyrequest.editor",
        "displayName": "EasyRequest",
        "selector": [
          {
            "filenamePattern": "*.erequest"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "easyrequest.newCollection",
        "title": "EasyRequest: Nueva colección"
      }
    ],
    "configuration": {
      "title": "EasyRequest",
      "properties": {
        "easyrequest.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 300000,
          "description": "Tiempo máximo de espera para una petición HTTP."
        },
        "easyrequest.maxBatchRequests": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 500,
          "description": "Máximo de solicitudes que puede lanzar una ráfaga."
        },
        "easyrequest.maxResponseSizeKb": {
          "type": "number",
          "default": 1024,
          "minimum": 64,
          "maximum": 10240,
          "description": "Tamaño máximo que se conserva por respuesta, en KiB."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "tsc -p . --noEmit && esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --sourcemap=external --outfile=dist/extension.js",
    "build:webview": "vite build --config webview/vite.config.ts",
    "watch": "concurrently -k \"npm:watch:extension\" \"npm:watch:webview\"",
    "watch:extension": "concurrently -k \"tsc -watch -p . --noEmit\" \"esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --sourcemap=external --outfile=dist/extension.js --watch\"",
    "watch:webview": "vite build --watch --config webview/vite.config.ts",
    "lint": "eslint src webview/src && tsc -p . --noEmit && tsc -p webview/tsconfig.json --noEmit",
    "compile:tests": "tsc -p .",
    "test": "npm run compile:tests && node --test out/test/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "18.19.130",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/vscode": "1.85.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vscode/vsce": "^3.7.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3"
  }
}
